rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /doctors/{doctorId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /slots/{slotId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['date', 'time', 'doctorId', 'duration']);
      allow update, delete: if request.auth != null;
    }

    match /appointments/{appointmentId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.keys().hasAll([
                         'slotId','date','time','patientName','petName',
                         'phone','email','service','duration','status','createdAt',
                         'doctorId','doctorName']);
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly([
                           'status', 'notes', 'duration',
                           'patientName', 'petName', 'phone', 'email', 'service', 'time'
                         ]);
      allow delete: if request.auth != null;
    }

    match /schedule/{dateId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
